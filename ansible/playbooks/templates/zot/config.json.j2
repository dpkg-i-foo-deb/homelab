{
  "storage": {
    "rootDirectory": "/var/lib/registry",
    "gc": true,
    "gcInterval": "24h",
    "gcDelay": "2h",
    "retention": {
      "dryRun": false,
      "delay": "24h",
      "policies": [
        {
          "repositories": [
            "**"
          ],
          "deleteUntagged": true,
          "keepTags": [
            {
              "pulledWithin": "720h",
              "pushedWithin": "720h"
            }
          ]
        }
      ]
    }
  },
  "http": {
    "address": "0.0.0.0",
    "port": "5000",
    "compat": [
      "docker2s2"
    ],
    "auth": {
      "failDelay": 5,
      "htpasswd": {
        "path": "/etc/zot/htpass"
      }
    }
  },
  "log": {
    "level": "debug"
  },
  "extensions": {
    "search": {
      "enable": true,
      "cve": {
        "updateInterval": "{{ registry_cve_update_interval }}"
      }
    },
    "ui": {
      "enable": {{ registry_enable_ui }}
    },
    "mgmt": {
      "enable": true
    },
    "sync": {
      "enable": true,
      "credentialsFile": "/etc/zot/sync-creds.json",
      "registries": [
        {
          "urls": [
            "https://index.docker.io"
          ],
          "onDemand": true,
          "tlsVerify": true,
          "content": [
            {
              "prefix": "**",
              "destination": "/dockerhub"
            }
          ]
        },
        {
          "urls": [
            "https://quay.io"
          ],
          "onDemand": true,
          "tlsVerify": true,
          "content": [
            {
              "prefix": "**",
              "destination": "/quay"
            }
          ]
        },
        {
          "urls": [
            "https://ghcr.io"
          ],
          "onDemand": true,
          "tlsVerify": true,
          "content": [
            {
              "prefix": "**",
              "destination": "/ghcr"
            }
          ]
        }
      ]
    }
  }
}

