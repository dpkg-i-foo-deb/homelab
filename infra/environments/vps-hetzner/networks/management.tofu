resource "incus_network" "management" {
  name = "management"
  type = "bridge"
  config = {
    "ipv4.address" = "10.0.251.1/24"
    "ipv4.nat"     = true
    # "dns.nameservers" = "10.0.2.2"
    "ipv4.dhcp.routes" = join(",", [
      "0.0.0.0/0,10.0.251.1",
      "10.0.0.0/24,10.0.251.20",
      "10.0.1.0/24,10.0.251.20",
      "10.0.2.0/24,10.0.251.20",
      "10.0.3.0/24,10.0.251.20",
      "10.0.4.0/24,10.0.251.20",
      "10.0.5.0/24,10.0.251.20",
      "10.0.6.0/24,10.0.251.20",
      "10.0.7.0/24,10.0.251.20",
      "10.0.8.0/24,10.0.251.20"
    ])
  }
}
